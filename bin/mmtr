#!/usr/bin/env sh

if ! command -v mtr >&/dev/null 2>&1; then
    murasaki="\033[38;5;135m"
    nocolor="\033[m"
    if [ -f /opt/homebrew/sbin/mtr ] && false ; then
        echo "Bin exists: ${murasaki}/opt/homebrew/sbin/mtr${nocolor}"
        echo "Add into PATH: ${murasaki}/opt/homebrew/sbin${nocolor}"
    else
        ps="${murasaki}"'$'"${nocolor}"
        echo "${ps} brew install mtr"
        echo "${ps} brew link mtr"
    fi
    exit 1
fi

if [ -n "$1" ]; then
    host="$1"
else
    host="8.8.8.8"
fi

while ! mtr "$host"; do sleep 1; done
